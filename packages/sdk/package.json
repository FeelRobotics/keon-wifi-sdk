{
  "name": "@feelrobotics/keon-wifi-sdk",
  "version": "1.0.0",
  "description": "Framework-agnostic SDK for provisioning and controlling Keon WiFi devices over Bluetooth LE and WebSocket.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FeelRobotics/keon-wifi-sdk.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/FeelRobotics/keon-wifi-sdk/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/FeelRobotics/keon-wifi-sdk/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup",
    "test": "jest --coverage --json --outputFile=coverage/test-results.json && node tools/test-summary.js",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepack": "yarn build",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "author": "OleksiyB",
  "license": "MIT",
  "keywords": [
    "Keon",
    "Keon WiFi",
    "Keon WiFi SDK",
    "feelrobotics",
    "kiiroo",
    "bluetooth",
    "ble",
    "wifi",
    "provisioning"
  ],
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB",
      "ignore": [
        "socket.io-client",
        "jwt-decode"
      ]
    },
    {
      "path": "dist/index.mjs",
      "limit": "10 KB",
      "ignore": [
        "socket.io-client",
        "jwt-decode"
      ]
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.18",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "size-limit": "^11.2.0",
    "ts-jest": "^29.3.2",
    "tslib": "^2.8.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "jwt-decode": "^4.0.0",
    "socket.io-client": "^4.8.1"
  }
}
