{
  "name": "@feelrobotics/keon-wifi-sdk-react",
  "version": "1.0.0",
  "description": "React hook for the Keon WiFi SDK — provision and control Keon WiFi devices.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FeelRobotics/keon-wifi-sdk.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/FeelRobotics/keon-wifi-sdk/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/FeelRobotics/keon-wifi-sdk/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "prepack": "yarn build"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "author": "OleksiyB",
  "license": "MIT",
  "keywords": [
    "Keon",
    "Keon WiFi",
    "feelrobotics",
    "kiiroo",
    "react",
    "hook",
    "bluetooth",
    "wifi",
    "provisioning"
  ],
  "dependencies": {
    "@feelrobotics/keon-wifi-sdk": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "react": "^19.1.0",
    "tslib": "^2.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  }
}
