# =============================================================================
# Keon Device Emulator — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# --- AWS Cognito User Pool ---
# Region where the Cognito User Pool is deployed.
#VITE_COGNITO_REGION=us-east-1
# The App Client ID registered in the User Pool.
#VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# --- FeelMe OAuth Server ---
# Base URL of the OAuth server. Defaults to FEC US Production.
#VITE_OAUTH_SERVER_URL=https://oauth-fec-us.feelme.com

# --- FeelExchangeCenter WebSocket ---
# WebSocket base URL for the FeelExchangeCenter relay server.
# Defaults to Production. For staging use: https://fec-stg.feelme.com
#VITE_FEC_SERVER_URL=https://fec.feelme.com
